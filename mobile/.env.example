# ============================================
# RegenX Mobile App - Variables d'environnement
# ============================================
# Copiez ce fichier en .env et remplissez les valeurs
# cp .env.example .env

# --------------------------------------------
# Supabase (obligatoire)
# --------------------------------------------
# Trouvez ces valeurs dans : Supabase Dashboard > Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --------------------------------------------
# API RegenX (Next.js backend)
# --------------------------------------------
# URL de votre app Vercel en production
EXPO_PUBLIC_API_URL=https://your-app.vercel.app
# Pour le développement local avec Expo :
# EXPO_PUBLIC_API_URL=http://192.168.x.x:3000

# --------------------------------------------
# PostHog Analytics (optionnel)
# --------------------------------------------
# Trouvez ces valeurs dans : PostHog Dashboard > Settings > Project
EXPO_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# --------------------------------------------
# OpenAI (optionnel - configuré côté serveur)
# --------------------------------------------
# NE PAS mettre la clé OpenAI ici - elle doit rester côté serveur (Next.js)
# Configurez OPENAI_API_KEY dans les variables d'environnement Vercel

# --------------------------------------------
# Stripe (optionnel - pour les paiements in-app)
# --------------------------------------------
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
